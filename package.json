{
  "name": "CodeLineCounter",
  "displayName": "CodeLineCounter",
  "description": "A tool for learn how much line of code your project contains",
  "version": "1.0.1",
  "publisher": "KebanFiru",
  "license": "MIT",
  "homepage": "https://github.com/KebanFiru/CodeCount#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/KebanFiru/CodeCount.git"
  },
  "bugs": {
    "url": "https://github.com/KebanFiru/CodeCount/issues"
  },
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codecount.countLines",
    "onCommand:codecount.countFilesLines",
    "onCommand:codecount.countLinesByExtension",
    "onCommand:codecount.refreshStats",
    "onCommand:codecount.gitRepoMissing",
    "onView:codecount.stats"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codecount",
          "title": "CodeCount",
          "icon": "resources/codecount.svg"
        }
      ]
    },
    "views": {
      "codecount": [
        {
          "id": "codecount.stats",
          "name": "CodeCount"
        }
      ]
    },
    "commands": [
      {
        "command": "codecount.countLines",
        "title": "Count Lines of Code"
      },
      {
        "command": "codecount.countFilesLines",
        "title": "Count Lines of Code in All Files"
      },
      {
        "command": "codecount.countLinesByExtension",
        "title": "Count Lines of Code by Extension"
      },
      {
        "command": "codecount.refreshStats",
        "title": "Refresh CodeCount Stats"
      },
      {
        "command": "codecount.gitRepoMissing",
        "title": "Git Repo Missing"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codecount.refreshStats",
          "when": "view == codecount.stats",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.19.17",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
